<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="12dp">

    <CheckBox
        android:id="@+id/cbLibraryItem"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="4dp"
        android:buttonTint="@color/brand_primary" />

    <TextView
        android:id="@+id/tvLibraryItemTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textSize="15sp"
        android:textColor="@color/text_primary"
        android:maxLines="2"
        android:ellipsize="end" />

    <ImageButton
        android:id="@+id/btnLibraryItemDelete"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginStart="8dp"
        android:background="@drawable/bg_circle_button_danger"
        android:src="@drawable/ic_clear"
        android:contentDescription="@string/content_desc_delete"
        android:padding="8dp"
        android:scaleType="fitCenter" />
</LinearLayout>
