<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_header"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="9dp">

        <ImageView
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@drawable/ic_app_logo"
            android:contentDescription="Logo" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:text="@string/app_name"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:letterSpacing="0.01" />

        <ImageButton
            android:id="@+id/btnMoreMenu"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_more"
            android:contentDescription="Další možnosti"
            android:padding="6dp"
            android:scaleType="fitCenter" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="14dp">

        <ProgressBar
            android:id="@+id/progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:indeterminate="true"
            android:visibility="gone"
            android:layout_marginBottom="8dp" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginBottom="8dp">

            <EditText
                android:id="@+id/etContent"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="top|start"
                android:inputType="textMultiLine"
                android:background="@drawable/bg_edittext_rounded"
                android:padding="14dp"
                android:textSize="17sp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:hint="Sem vlož nebo napiš text ke čtení…"
                android:scrollbars="vertical"
                android:scrollbarStyle="outsideOverlay"
                android:fadeScrollbars="false"
                android:scrollbarThumbVertical="@drawable/scrollbar_thumb"
                android:scrollbarSize="6dp" />

            <!-- Neviditelná vrstva přes pravý okraj - dotek + tažení kdekoli v ní
                 rovnou posune text (na rozdíl od systémového scrollbaru, který je
                 jen vizuální indikátor a nejde ho chytit prstem). -->
            <View
                android:id="@+id/scrollDragHandle"
                android:layout_width="32dp"
                android:layout_height="match_parent"
                android:layout_gravity="end"
                android:background="@android:color/transparent" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPaste"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:minWidth="0dp"
                android:layout_marginEnd="6dp"
                android:text="Vložit"
                android:textAllCaps="false"
                app:icon="@drawable/ic_paste"
                app:iconGravity="textStart"
                app:cornerRadius="14dp"
                app:backgroundTint="@color/text_secondary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnClear"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:minWidth="0dp"
                android:layout_marginStart="6dp"
                android:text="Vymazat"
                android:textAllCaps="false"
                app:icon="@drawable/ic_clear"
                app:iconGravity="textStart"
                app:cornerRadius="14dp"
                app:backgroundTint="@color/brand_danger" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_toolbar_pill"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:layout_marginBottom="6dp">

            <ImageButton
                android:id="@+id/btnImage"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_image"
                android:tint="@color/brand_accent"
                android:contentDescription="Rozpoznat text z obrázku"
                android:padding="9dp"
                android:scaleType="fitCenter" />

            <View
                android:layout_width="1dp"
                android:layout_height="24dp"
                android:layout_marginStart="1dp"
                android:layout_marginEnd="1dp"
                android:background="@color/border" />

            <ImageButton
                android:id="@+id/btnLink"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_link"
                android:tint="@color/brand_accent"
                android:contentDescription="Načíst text z odkazu"
                android:padding="9dp"
                android:scaleType="fitCenter" />

            <!-- Výraznější oddělovač mezi skupinou "import obsahu" a "knihovna" -->
            <View
                android:layout_width="1.5dp"
                android:layout_height="30dp"
                android:layout_marginStart="9dp"
                android:layout_marginEnd="9dp"
                android:background="@color/text_secondary" />

            <ImageButton
                android:id="@+id/btnSave"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_save"
                android:tint="@color/icon_secondary"
                android:contentDescription="Uložit do knihovny"
                android:padding="9dp"
                android:scaleType="fitCenter" />

            <View
                android:layout_width="1dp"
                android:layout_height="24dp"
                android:layout_marginStart="1dp"
                android:layout_marginEnd="1dp"
                android:background="@color/border" />

            <ImageButton
                android:id="@+id/btnLibrary"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_library"
                android:tint="@color/icon_secondary"
                android:contentDescription="Otevřít knihovnu textů"
                android:padding="9dp"
                android:scaleType="fitCenter" />

            <View
                android:layout_width="1dp"
                android:layout_height="24dp"
                android:layout_marginStart="1dp"
                android:layout_marginEnd="1dp"
                android:background="@color/border" />

            <ImageButton
                android:id="@+id/btnHistory"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_history"
                android:tint="@color/icon_secondary"
                android:contentDescription="Historie čtení"
                android:padding="9dp"
                android:scaleType="fitCenter" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_edittext_rounded"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rychlost"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:layout_marginEnd="6dp" />

            <ImageButton
                android:id="@+id/btnSpeedMinus"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_circle_button"
                android:src="@drawable/ic_minus"
                android:contentDescription="Zpomalit"
                android:padding="7dp"
                android:scaleType="fitCenter" />

            <SeekBar
                android:id="@+id/seekSpeed"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:progressTint="@color/brand_primary"
                android:thumbTint="@color/brand_primary" />

            <ImageButton
                android:id="@+id/btnSpeedPlus"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_circle_button"
                android:src="@drawable/ic_plus"
                android:contentDescription="Zrychlit"
                android:padding="7dp"
                android:scaleType="fitCenter" />

            <TextView
                android:id="@+id/tvSpeedValue"
                android:layout_width="46dp"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/brand_primary"
                android:text="1.0x" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical|center_horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPlayPause"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:insetLeft="0dp"
                    android:insetRight="0dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="Přehrát"
                    android:textAllCaps="false"
                    android:textSize="15sp"
                    app:icon="@drawable/ic_play"
                    app:iconGravity="textStart"
                    app:iconPadding="6dp"
                    app:cornerRadius="15dp"
                    app:backgroundTint="@color/brand_play" />
            </LinearLayout>

            <ImageButton
                android:id="@+id/btnSkipPrev"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_circle_button"
                android:src="@drawable/ic_skip_prev"
                android:contentDescription="Předchozí odstavec"
                android:padding="10dp"
                android:scaleType="fitCenter" />

            <ImageButton
                android:id="@+id/btnSkipNext"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_circle_button"
                android:src="@drawable/ic_skip_next"
                android:contentDescription="Další odstavec"
                android:padding="10dp"
                android:scaleType="fitCenter" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnStop"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:insetLeft="0dp"
                    android:insetRight="0dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="Stop"
                    android:textAllCaps="false"
                    android:textSize="15sp"
                    app:icon="@drawable/ic_stop"
                    app:iconGravity="textStart"
                    app:iconPadding="6dp"
                    app:cornerRadius="15dp"
                    app:backgroundTint="@color/brand_accent" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
